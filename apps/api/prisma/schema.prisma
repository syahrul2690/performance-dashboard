model KontrakManajemen {
  id          String    @id @default(cuid())
  periodId    String
  unitCode    String
  bidang      String
  holder      String
  kpiItems    Json
  status      String    @default("draft") // draft | submitted | approved | rejected
  currentStage Int      @default(1) // 1=Staff 2=Asman 3=Manajer 4=Sr.Manajer (final)
  history     Json      @default("[]")
  submitter   String
  submitterId String?
  reviewer    String?
  reviewNote  String?
  reviewedAt  DateTime?
  submittedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([periodId, unitCode])
  @@map("kontrak_manajemen")
}

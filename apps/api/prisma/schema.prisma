generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STAFF
  ASMAN
  MANAJER
  SRMANAJER
  GM
  SUPERADMIN
  DEVELOPER
}

enum ReportStatus {
  DRAFT
  IN_REVIEW
  NEEDS_REVISION
  APPROVED
}

enum KMDocStatus {
  IN_REVIEW_C1
  IN_REVIEW_C2
  IN_REVIEW_SM
  APPROVED
  RETURNED
}

enum KMDocType {
  WF1
  WF1B
  WF2
  WF3
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role
  unit         String
  bidang       String?  // Bidang asal user (null = lintas-bidang, mis. GM)
  phone        String?  // Nomor WhatsApp untuk notifikasi (simulasi — belum terhubung provider nyata)
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  notifications Notification[]
  prefs         UserPrefs?

  roleVariantId String?
  roleVariant   RoleVariant? @relation(fields: [roleVariantId], references: [id])

  @@map("users")
}

// Katalog varian peran (jabatan + lingkup) per tier — selaras dengan
// taksonomi organisasi prototipe. Enum Role tetap = 5 tier (level izin).
model RoleVariant {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  tier      Role
  scope     String
  createdAt DateTime @default(now())

  users User[]

  @@map("role_variants")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model UserPrefs {
  id                String  @id @default(cuid())
  userId            String  @unique
  theme             String  @default("light")
  notifyEmail       Boolean @default(true)
  notifyInApp       Boolean @default(true)
  notifyWhatsapp    Boolean @default(false)
  digestFrequency   String  @default("daily")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_prefs")
}

model Period {
  id        String   @id @default(cuid())
  yearMonth String   @unique
  label     String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  // Override manual GM/Admin: buka paksa window pengisian realisasi di luar jadwal tgl 25-5.
  windowOverride Boolean   @default(false)
  overrideBy     String?
  overrideAt     DateTime?

  // Acuan aktif KM untuk pengisian realisasi periode ini: 'draft' atau 'final'.
  // Default cerdas saat seed (Jan-Jun='draft', Jul-Des='final'), dapat diubah GM/Admin
  // kapan pun (mis. KM Final belum disahkan Direksi meski sudah masuk semester II).
  kmReference String @default("draft") // 'draft' | 'final'

  @@map("periods")
}

// Executive + domain KPI snapshots stored as typed JSON blobs per period.
// This mirrors the prototype's DATA structure exactly so the seed is a simple JSON.parse.
model ExecutiveSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("executive_snapshots")
}

model FinancialSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("financial_snapshots")
}

model OperationalSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("operational_snapshots")
}

model StrategicSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("strategic_snapshots")
}

model HumanCapitalSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("human_capital_snapshots")
}

model RiskSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("risk_snapshots")
}

model Report {
  id           String       @id @default(cuid())
  unit         String
  periodId     String
  currentStage Int          @default(1)
  status       ReportStatus @default(DRAFT)
  nextApprover String?
  history      Json         @default("[]")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([unit, periodId])
  @@map("reports")
}

model KMDocument {
  id          String      @id @default(cuid())
  docId       String      @unique
  tipe        KMDocType
  bidangUnit  String
  holder      String
  status      KMDocStatus
  deadline    DateTime?
  slaRemain   Int?
  attachments Json        @default("[]")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  reviews KMReview[]

  @@map("km_documents")
}

model KMReview {
  id         String   @id @default(cuid())
  docId      String
  actor      String
  action     String
  note       String?
  createdAt  DateTime @default(now())

  document KMDocument @relation(fields: [docId], references: [docId], onDelete: Cascade)

  @@map("km_reviews")
}

model InputRealisasi {
  id           String    @id @default(cuid())
  periodId     String
  unitCode     String
  bidang       String    @default("") // Realisasi dipecah per bidang
  submitter    String
  submitterId  String?
  values       Json
  // Snapshot nilai self-assessment persis seperti diinput UPMK saat submit — DIKUNCI,
  // tidak pernah diubah oleh reviewer. `values` di atas tetap jadi salinan kerja yang
  // dapat dikoreksi reviewer sepanjang alur (hasil evaluasi RPC/KI).
  selfAssessment Json?
  status       String    @default("draft") // draft | submitted | ready | approved | rejected
  currentStage Int       @default(1) // legacy; kini = currentStepIndex
  steps        Json      @default("[]") // template langkah alur (urut) — mesin alur multi-segmen
  currentStepIndex Int   @default(0)    // pointer ke langkah berjalan dalam `steps`
  attachments  Json      @default("[]") // evidence: [{id,name,size,type,uploadedAt}]
  history      Json      @default("[]")
  reviewer     String?
  reviewNote   String?
  reviewedAt   DateTime?
  submittedAt  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([periodId, unitCode, bidang])
  @@map("input_realisasi")
}

// Dokumen konsolidasi realisasi per periode — dikumpulkan sistem dari semua
// slice realisasi (semua bidang KI + semua UPMK) yang sudah lolos sampai SM RPC,
// lalu disetujui SEKALI oleh General Manager.
model RealisasiBundle {
  id         String    @id @default(cuid())
  periodId   String    @unique
  status     String    @default("open") // open | approved | rejected
  reviewer   String?
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("realisasi_bundles")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  title     String
  msg       String
  route     String?
  targetId  String?
  unread    Boolean  @default(true)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

// Log simulasi pengingat WhatsApp ke Checker selama window pengisian realisasi.
// Belum terhubung provider nyata (Fonnte/WA Business API) — hanya mencatat pesan
// yang AKAN dikirim, untuk demo & validasi konten sebelum integrasi produksi.
model WhatsAppLog {
  id            String   @id @default(cuid())
  periodId      String
  recipientId   String
  recipientName String
  phone         String?
  templateType  String   // 'reminder_checker'
  message       String
  pendingCount  Int      @default(0)
  forced        Boolean  @default(false) // true bila dipicu manual (bukan jadwal otomatis 3-harian)
  createdAt     DateTime @default(now())

  @@map("whatsapp_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  actor     String
  action    String
  entity    String?
  targetId  String?
  note      String?
  diff      Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model ProsesBisnisSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("proses_bisnis_snapshots")
}

model OrganisasiSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])

model PetaSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("peta_snapshots")
}

model KontrakManajemen {
  id          String    @id @default(cuid())
  periodId    String
  unitCode    String
  bidang      String
  holder      String
  kpiItems    Json
  status      String    @default("draft") // draft | submitted | ready | approved | rejected
  // kmType: dokumen KM DRAFT (acuan Jan-Jun, sebelum disahkan Direksi) vs KM FINAL
  // (disahkan Direksi di luar sistem, biasanya acuan Jul-Des). Dua dokumen independen,
  // masing-masing punya alur submit/review/bundle sendiri — bukan revisi dari yang lain.
  kmType      String    @default("draft") // 'draft' | 'final'
  currentStage Int      @default(1) // legacy; kini = currentStepIndex
  steps        Json     @default("[]") // mesin alur multi-segmen (sama seperti realisasi)
  currentStepIndex Int  @default(0)
  history     Json      @default("[]")
  submitter   String
  submitterId String?
  reviewer    String?
  reviewNote  String?
  reviewedAt  DateTime?
  submittedAt DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([periodId, unitCode])
  @@index([kmType])
  @@map("kontrak_manajemen")
}

// Konsolidasi KM per TAHUN per SCOPE per TIPE (Draft/Final) — GM menyetujui masing-masing terpisah.
model KMBundle {
  id         String    @id @default(cuid())
  year       String
  scope      String    @default("KP") // 'KP' | 'UPMK'
  kmType     String    @default("draft") // 'draft' | 'final'
  status     String    @default("open") // open | approved | rejected
  reviewer   String?
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([year, scope, kmType])
  @@map("km_bundles")
}

// KPI sebagai entitas PARENT (Fase A). Satu definisi KPI dapat di-assign ke banyak
// unit/bidang (KpiAssignment). Saat di-assign, definisi disebar (fan-out) menjadi item
// pada kpiItems dokumen KontrakManajemen per-(unit,bidang) — bertanda masterKpiId —
// sehingga realisasi/snapshot/print tetap membaca bentuk kpiItems yang sama.
model KpiMaster {
  id           String   @id @default(cuid())
  year         String
  kmType       String   @default("draft") // 'draft' | 'final'
  indikator    String
  formula      String   @default("")
  satuan       String   @default("")
  targetParent String   @default("") // target gabungan (bisa non-numerik, mis. "Tanggal 5")
  createdBy    String
  createdById  String?
  status       String   @default("active") // active | superseded (Fase D — diganti versi lebih baru)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Default alur reviewer (Fase C) — diwariskan ke picker saat submit dokumen KM hasil
  // fan-out dari KPI ini; submitter tetap bisa override sebelum kirim.
  defaultCheckerIds String[] @default([])
  defaultApproverId String?

  // Versioning (Fase D): edit atas definisi yang SEDANG BERLAKU tidak mengubah periode
  // berjalan — membuat versi baru berlaku bulan berikutnya (effectiveMonth). Versi lama
  // ditandai 'superseded' tanpa disentuh datanya. Master dgn effectiveMonth > periode aktif
  // ("pending", belum berlaku) masih boleh diedit langsung di tempat.
  effectiveMonth    String   // yearMonth mulai berlaku, mis. "2026-08"
  version           Int      @default(1)
  previousVersionId String?

  // Metode agregasi (Fase E) — dipilih per-KPI: 'weighted' = rata-rata tertimbang pakai
  // persenAgregasi (Σ=100%, cocok utk KPI positif); 'sum' = jumlah polos tiap kontribusi
  // (cocok utk KPI penalti/pengurang, tanpa syarat Σ=100%).
  aggregationMethod String @default("weighted") // 'weighted' | 'sum'

  assignments  KpiAssignment[]

  @@index([year, kmType])
  @@map("kpi_masters")
}

// Assignment satu KPI parent ke satu (unit, bidang). bobotKm = bobot skor KM (poin,
// existing); target per-assignment. Alur reviewer default menyusul (Fase C).
model KpiAssignment {
  id             String   @id @default(cuid())
  kpiMasterId    String
  unitCode       String
  bidang         String
  holder         String   @default("")
  bobotKm        String   @default("") // bobot skor KM (poin) — beda dari persen agregasi
  target         String   @default("") // Target Semester I per assignment
  target2        String   @default("") // Target tahunan per assignment
  // persenAgregasi: bobot rollup (0-100) ke nilai parent — diinput RPC Perencanaan,
  // total seluruh assignment dalam satu master harus = 100. Dipakai untuk hitung
  // nilai_parent = Σ(realisasi_child × persenAgregasi/100) setelah realisasi disetujui.
  persenAgregasi Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  master      KpiMaster @relation(fields: [kpiMasterId], references: [id], onDelete: Cascade)

  @@unique([kpiMasterId, unitCode, bidang])
  @@index([unitCode, bidang])
  @@map("kpi_assignments")
}

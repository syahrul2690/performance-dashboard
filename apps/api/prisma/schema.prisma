generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STAFF
  ASMAN
  MANAJER
  SRMANAJER
  GM
  SUPERADMIN
  DEVELOPER
}

enum ReportStatus {
  DRAFT
  IN_REVIEW
  NEEDS_REVISION
  APPROVED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role
  unit         String
  bidang       String? // Bidang asal user (null = lintas-bidang, mis. GM)
  phone        String? // Nomor WhatsApp untuk notifikasi (simulasi — belum terhubung provider nyata)
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  notifications Notification[]
  prefs         UserPrefs?

  roleVariantId String?
  roleVariant   RoleVariant? @relation(fields: [roleVariantId], references: [id])

  @@map("users")
}

// Katalog varian peran (jabatan + lingkup) per tier — selaras dengan
// taksonomi organisasi prototipe. Enum Role tetap = 5 tier (level izin).
model RoleVariant {
  id        String   @id @default(cuid())
  code      String   @unique
  label     String
  tier      Role
  scope     String
  createdAt DateTime @default(now())

  users User[]

  @@map("role_variants")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model UserPrefs {
  id              String  @id @default(cuid())
  userId          String  @unique
  theme           String  @default("light")
  notifyEmail     Boolean @default(true)
  notifyInApp     Boolean @default(true)
  notifyWhatsapp  Boolean @default(false)
  digestFrequency String  @default("daily")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_prefs")
}

model Period {
  id        String   @id @default(cuid())
  yearMonth String   @unique
  label     String
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  // Override manual GM/Admin: buka paksa window pengisian realisasi di luar jadwal tgl 25-5.
  windowOverride Boolean   @default(false)
  overrideBy     String?
  overrideAt     DateTime?

  // Acuan aktif KM untuk pengisian realisasi periode ini: 'draft' atau 'final'.
  // Default cerdas saat seed (Jan-Jun='draft', Jul-Des='final'), dapat diubah GM/Admin
  // kapan pun (mis. KM Final belum disahkan Direksi meski sudah masuk semester II).
  kmReference String @default("draft") // 'draft' | 'final'

  // Living-target workflow: deadline konvergensi bulanan (circuit-breaker) — saat lewat,
  // target-of-record PIC REN yang berlaku dibekukan paksa (lihat PeriodTargetService.forceFreeze).
  deadline   DateTime?
  // Diisi saat KM Final tiba dari holding & restatement dijalankan (lihat RestatementService).
  restatedAt DateTime?

  @@map("periods")
}

// Executive + domain KPI snapshots stored as typed JSON blobs per period.
// This mirrors the prototype's DATA structure exactly so the seed is a simple JSON.parse.
// Living-target workflow (fase Sementara→Final): dua snapshot berbeda per periode.
//   phase='sementara' → mutable, ditimpa tiap refresh selama masa tunggu KM Final.
//   phase='final'     → immutable, ditulis SEKALI saat restatement (KM Final tiba).
model ExecutiveSnapshot {
  id             String   @id @default(cuid())
  periodId       String
  phase          String   @default("sementara") // 'sementara' | 'final'
  targetOfRecord Json? // target per-KPI yang dipakai menghitung snapshot ini
  data           Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([periodId, phase])
  @@map("executive_snapshots")
}

model FinancialSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("financial_snapshots")
}

model OperationalSnapshot {
  id             String   @id @default(cuid())
  periodId       String
  phase          String   @default("sementara") // 'sementara' | 'final' — lihat catatan di ExecutiveSnapshot
  targetOfRecord Json?
  data           Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([periodId, phase])
  @@map("operational_snapshots")
}

model StrategicSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("strategic_snapshots")
}

model HumanCapitalSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("human_capital_snapshots")
}

model RiskSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("risk_snapshots")
}

model Report {
  id           String       @id @default(cuid())
  unit         String
  periodId     String
  currentStage Int          @default(1)
  status       ReportStatus @default(DRAFT)
  nextApprover String?
  history      Json         @default("[]")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([unit, periodId])
  @@map("reports")
}

model InputRealisasi {
  id               String    @id @default(cuid())
  periodId         String
  unitCode         String
  bidang           String    @default("") // Realisasi dipecah per bidang
  submitter        String
  submitterId      String?
  values           Json
  // Snapshot nilai self-assessment persis seperti diinput UPMK saat submit — DIKUNCI,
  // tidak pernah diubah oleh reviewer. `values` di atas tetap jadi salinan kerja yang
  // dapat dikoreksi reviewer sepanjang alur (hasil evaluasi RPC/KI).
  selfAssessment   Json?
  status           String    @default("draft") // draft | submitted | target_fix | ready | approved | rejected
  // Living-target workflow: snapshot target per-KPI (masterKpiId -> nilai target) yang berlaku
  // saat submit/resubmit terakhir — dipakai executive/operational service sbg "target-of-record"
  // alih-alih membaca target dari item KM statis. Diperbarui tiap re-submit (target selalu hidup
  // sampai KM Final tiba).
  targetOfRecord   Json?
  // 'sementara' selama masa tunggu KM Final; diset 'final' oleh restatement service.
  packagePhase     String    @default("sementara")
  currentStage     Int       @default(1) // legacy; kini = currentStepIndex
  steps            Json      @default("[]") // template langkah alur (urut) — mesin alur multi-segmen
  currentStepIndex Int       @default(0) // pointer ke langkah berjalan dalam `steps`
  attachments      Json      @default("[]") // evidence: [{id,name,size,type,uploadedAt}]
  history          Json      @default("[]")
  reviewer         String?
  reviewNote       String?
  reviewedAt       DateTime?
  submittedAt      DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([periodId, unitCode, bidang])
  @@map("input_realisasi")
}

// Dokumen konsolidasi realisasi per periode — dikumpulkan sistem dari semua
// slice realisasi (semua bidang KI + semua UPMK) yang sudah lolos sampai SM RPC,
// lalu disetujui SEKALI oleh General Manager.
model RealisasiBundle {
  id         String    @id @default(cuid())
  periodId   String    @unique
  status     String    @default("open") // open | approved | rejected
  reviewer   String?
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("realisasi_bundles")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  type      String
  title     String
  msg       String
  route     String?
  targetId  String?
  unread    Boolean  @default(true)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

// Log simulasi pengingat WhatsApp ke Checker selama window pengisian realisasi.
// Belum terhubung provider nyata (Fonnte/WA Business API) — hanya mencatat pesan
// yang AKAN dikirim, untuk demo & validasi konten sebelum integrasi produksi.
model WhatsAppLog {
  id            String   @id @default(cuid())
  periodId      String
  recipientId   String
  recipientName String
  phone         String?
  templateType  String // 'reminder_checker'
  message       String
  pendingCount  Int      @default(0)
  forced        Boolean  @default(false) // true bila dipicu manual (bukan jadwal otomatis 3-harian)
  createdAt     DateTime @default(now())

  @@map("whatsapp_logs")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  actor     String
  action    String
  entity    String?
  targetId  String?
  note      String?
  diff      Json?
  ip        String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model ProsesBisnisSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("proses_bisnis_snapshots")
}

model OrganisasiSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("organisasi_snapshots")
}

model GcgEsgSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("gcg_esg_snapshots")
}

model PetaSnapshot {
  id        String   @id @default(cuid())
  periodId  String
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([periodId])
  @@map("peta_snapshots")
}

model KontrakManajemen {
  id               String    @id @default(cuid())
  periodId         String
  unitCode         String
  bidang           String
  holder           String
  kpiItems         Json
  status           String    @default("draft") // draft | submitted | ready | approved | rejected
  // kmType: dokumen KM DRAFT (acuan Jan-Jun, sebelum disahkan Direksi) vs KM FINAL
  // (disahkan Direksi di luar sistem, biasanya acuan Jul-Des). Dua dokumen independen,
  // masing-masing punya alur submit/review/bundle sendiri — bukan revisi dari yang lain.
  kmType           String    @default("draft") // 'draft' | 'final'
  currentStage     Int       @default(1) // legacy; kini = currentStepIndex
  steps            Json      @default("[]") // mesin alur multi-segmen (sama seperti realisasi)
  currentStepIndex Int       @default(0)
  history          Json      @default("[]")
  submitter        String
  submitterId      String?
  reviewer         String?
  reviewNote       String?
  reviewedAt       DateTime?
  submittedAt      DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([periodId, unitCode])
  @@index([kmType])
  @@map("kontrak_manajemen")
}

// Konsolidasi KM per TAHUN per SCOPE per TIPE (Draft/Final) — GM menyetujui masing-masing terpisah.
model KMBundle {
  id         String    @id @default(cuid())
  year       String
  scope      String    @default("KP") // 'KP' | 'UPMK'
  kmType     String    @default("draft") // 'draft' | 'final'
  status     String    @default("open") // open | approved | rejected
  reviewer   String?
  reviewNote String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([year, scope, kmType])
  @@map("km_bundles")
}

// KPI sebagai entitas PARENT (Fase A). Satu definisi KPI dapat di-assign ke banyak
// unit/bidang (KpiAssignment). Saat di-assign, definisi disebar (fan-out) menjadi item
// pada kpiItems dokumen KontrakManajemen per-(unit,bidang) — bertanda masterKpiId —
// sehingga realisasi/snapshot/print tetap membaca bentuk kpiItems yang sama.
model KpiMaster {
  id           String   @id @default(cuid())
  year         String
  kmType       String   @default("draft") // 'draft' | 'final'
  indikator    String
  formula      String   @default("")
  satuan       String   @default("")
  bobotKm      String   @default("") // bobot skor KM (poin) — satu nilai per-KPI, sama utk semua assignment
  targetParent String   @default("") // target gabungan (bisa non-numerik, mis. "Tanggal 5")
  createdBy    String
  createdById  String?
  status       String   @default("active") // active | superseded (Fase D — diganti versi lebih baru)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Default alur reviewer (Fase C) — diwariskan ke picker saat submit dokumen KM hasil
  // fan-out dari KPI ini; submitter tetap bisa override sebelum kirim.
  defaultCheckerIds String[] @default([])
  defaultApproverId String?

  // Versioning (Fase D): edit atas definisi yang SEDANG BERLAKU tidak mengubah periode
  // berjalan — membuat versi baru berlaku bulan berikutnya (effectiveMonth). Versi lama
  // ditandai 'superseded' tanpa disentuh datanya. Master dgn effectiveMonth > periode aktif
  // ("pending", belum berlaku) masih boleh diedit langsung di tempat.
  effectiveMonth    String // yearMonth mulai berlaku, mis. "2026-08"
  version           Int     @default(1)
  previousVersionId String?

  // Metode agregasi (Fase E) — dipilih per-KPI: 'weighted' = rata-rata tertimbang pakai
  // persenAgregasi (Σ=100%, cocok utk KPI positif); 'sum' = jumlah polos tiap kontribusi
  // (cocok utk KPI penalti/pengurang, tanpa syarat Σ=100%).
  aggregationMethod String @default("weighted") // 'weighted' | 'sum'

  // Sub-indikator (opt-in, generik — KPI mana pun boleh dipakai, bukan hardcode nama).
  // Array [{ nama, satuan, bobot, target, target2? }]. Non-kosong = KPI ini "komposit":
  // bobot/target tingkat induk (KpiAssignment.bobotKm/target/target2) jadi TURUNAN
  // (Σ dari sub), dan realisasi diisi per-sub (bukan satu angka induk). Lihat
  // common/capaian.ts scoreItems() untuk rollup nilai induk = Σ nilai sub.
  subIndicators Json?

  assignments KpiAssignment[]

  @@index([year, kmType])
  @@map("kpi_masters")
}

// Assignment satu KPI parent ke satu (unit, bidang). Target per-assignment; bobotKm kini
// data parent di KpiMaster (satu nilai untuk seluruh assignment KPI ini).
model KpiAssignment {
  id             String   @id @default(cuid())
  kpiMasterId    String
  unitCode       String
  bidang         String
  holder         String   @default("")
  target         String   @default("") // Target Semester I per assignment
  target2        String   @default("") // Target tahunan per assignment
  // persenAgregasi: bobot rollup (0-100) ke nilai parent — diinput RPC Perencanaan,
  // total seluruh assignment dalam satu master harus = 100. Dipakai untuk hitung
  // nilai_parent = Σ(realisasi_child × persenAgregasi/100) setelah realisasi disetujui.
  persenAgregasi Float    @default(0)
  // Default alur reviewer per-assignment (A+B). Bentuk: { checkers: Slot[], approver: Slot|null }
  // dengan Slot = { role: 'ASMAN'|'MANAJER'|'SRMANAJER'|'GM', userId?: string }.
  //   role saja  → resolve ke orang saat submit, di-scope (unitCode,bidang) assignment (B)
  //   userId ada → override ke orang spesifik (A)
  //   null       → fallback ke default master-level (KpiMaster.defaultCheckerIds/ApproverId)
  reviewerSlots  Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  master        KpiMaster      @relation(fields: [kpiMasterId], references: [id], onDelete: Cascade)
  periodTargets PeriodTarget[]

  @@unique([kpiMasterId, unitCode, bidang])
  @@index([unitCode, bidang])
  @@map("kpi_assignments")
}

// Persetujuan konsolidasi agregat KPI lintas-bidang (Fase H2). Setelah semua bidang
// kontributor menyetujui realisasinya (InputRealisasi approved), RPC Perencanaan meninjau
// & menyetujui nilai PARENT (agregat) sebelum dianggap final. Satu review per (KPI,periode).
model KpiRollupReview {
  id          String    @id @default(cuid())
  kpiMasterId String
  periodId    String
  status      String    @default("pending") // pending | approved | rejected
  reviewer    String?
  reviewerId  String?
  reviewNote  String?
  nilaiParent Float? // snapshot nilai agregat yang dikunci saat disetujui
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([kpiMasterId, periodId])
  @@index([periodId])
  @@map("kpi_rollup_reviews")
}

// Living-target workflow: instance target "KM Sementara" per (periode, assignment) — hidup
// & bisa dikoreksi PIC REN sepanjang masa tunggu KM Final. `target` = KpiAssignment.target
// tetap jadi definisi default/struktural; baris ini adalah nilai OPERASIONAL bulan berjalan.
model PeriodTarget {
  id              String    @id @default(cuid())
  periodId        String
  kpiAssignmentId String
  target          String    @default("") // target hidup bulan ini (living)
  source          String    @default("fresh") // 'fresh' (input baru) | 'carried' (dari bulan lalu)
  frozen          Boolean   @default(false) // true setelah bundle GM disetujui / deadline lewat / restatement
  frozenTarget    String? // target-of-record yang dikunci saat freeze
  frozenAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assignment KpiAssignment @relation(fields: [kpiAssignmentId], references: [id], onDelete: Cascade)

  @@unique([periodId, kpiAssignmentId])
  @@index([periodId])
  @@map("period_targets")
}

// Jejak audit append-only simetris untuk koreksi target (PeriodTarget) maupun realisasi
// (InputRealisasi.values) — pelengkap `InputRealisasi.history` yang mencatat level LANGKAH,
// baris ini mencatat level NILAI (diff lama→baru per field).
model RevisionLog {
  id        String   @id @default(cuid())
  entity    String // 'period_target' | 'input_realisasi'
  targetId  String // id baris yang direvisi
  periodId  String
  actor     String
  actorId   String?
  field     String? // mis. 'target' | 'values'
  oldValue  Json?
  newValue  Json?
  note      String?
  createdAt DateTime @default(now())

  @@index([entity, targetId])
  @@index([periodId])
  @@map("revision_logs")
}

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://pusmanpro:pusmanpro@localhost:5433/pusmanpro_db

# PostgreSQL (docker-compose dev)
POSTGRES_USER=pusmanpro
POSTGRES_PASSWORD=pusmanpro
POSTGRES_DB=pusmanpro_db

# ── JWT (generate: openssl rand -hex 64) ─────────────────
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── Demo seed accounts (shared password) ─────────────────
DEMO_PASSWORD=Pusmanpro@2026

# ── API ──────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false

# ── Domain (prod only, no https://) ──────────────────────
DOMAIN=localhost
